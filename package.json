{
  "name": "vscode-worktree-window-title",
  "displayName": "Worktree Window Title",
  "description": "Show the git worktree folder name in your VS Code window title",
  "version": "1.0.0",
  "publisher": "garytyler",
  "repository": {
    "type": "git",
    "url": "https://github.com/garytyler/vscode-worktree-window-title"
  },
  "license": "MIT",
  "icon": "assets/icon.png",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "Worktree Title",
      "properties": {
        "worktreeTitle.template": {
          "type": "string",
          "default": "",
          "markdownDescription": "Window title template. Use `${worktreeName}` for the worktree folder name. Standard VS Code variables like `${dirty}`, `${activeEditorShort}`, `${separator}` also work. **This replaces `window.title` when set.**\n\nExample: `${worktreeName}${separator}${dirty}${activeEditorShort}`"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/node": "^18.0.0",
    "@types/vscode": "^1.74.0",
    "@typescript-eslint/eslint-plugin": "^8.52.0",
    "@typescript-eslint/parser": "^8.52.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.7.4",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.52.0"
  }
}